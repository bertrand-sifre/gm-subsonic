node_modules
dist
.nx
*.log
.DS_Store

# Binaire C++ gdm compilé sur l'hôte (artefact spécifique à la plateforme ;
# le binaire embarqué est compilé dans le stage Docker `gdmbuilder`).
tools/gdm/build/

# Réglages Claude Code locaux (machine).
.claude/settings.local.json

# Fixtures audio générées (régénérables via `npm run fixtures`).
# Seul media/meta.json (la source) est versionné.
media/*.wav
media/*.ogg

# Manifeste catalogué + cache des rendus à la demande (régénérables :
# `npm run library:import` pour le manifeste, le cache se remplit à la lecture).
media/_decoded/
media/_cache/
media/_stems/
media/library.generated.json
media/loops.cache.json
media/stems.cache.json

# Script de spike (prototype de détection de boucle, non versionné).
/_spike_loop.cjs

# Bibliothèque locale : vrais fichiers VGM déposés (souvent copyrightés) —
# non versionnés. Seuls README et .gitkeep le sont.
/library/*
!/library/.gitkeep
!/library/README.md
