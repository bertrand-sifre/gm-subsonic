{
  "name": "vdm-subsonic",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "scripts": {
    "fixtures": "node tools/gen-fixtures.mjs",
    "library:import": "node tools/import-library.mjs",
    "dev": "nx run-many -t serve --parallel=2",
    "build": "nx run-many -t build",
    "build:gdm": "nx run gdm:compile",
    "typecheck": "nx run-many -t typecheck",
    "serve:server": "nx serve server",
    "serve:web": "nx serve web"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.14.0",
    "nx": "^19.8.4",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "tslib": "^2.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.8"
  }
}
